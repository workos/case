# Case harness marker files (created during pipeline runs)
.case-active
.case-tested
.case-manual-tested
.case-reviewed

# Phase 3: state moved to ~/.config/case/. These rules cover both the legacy
# in-repo paths (during the transition window) and any state accidentally written
# under the repo root.
tasks/active/
tasks/done/
docs/learnings/
docs/proposed-amendments/*.md
!docs/proposed-amendments/.gitkeep
docs/run-log.jsonl
docs/agent-versions/

# Ideation artifacts (generated HTML/MD specs)
docs/ideation/

# Build artifacts
node_modules/
dist/

# bun artifacts
*.bun-build
