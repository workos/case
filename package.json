{
  "name": "@case/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "xcase": "src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "bun test ./src/__tests__/ && bun test --cwd test/standalone",
    "start": "bun src/index.ts",
    "serve": "bun src/index.ts serve"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.60.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-coding-agent": "^0.60.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.7.0"
  }
}
