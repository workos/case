{
  "name": "case",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ca": "src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "bun test ./src/__tests__/ && bun test --cwd test/standalone",
    "test:ast": "bash tests/ast-rules/run-tests.sh",
    "lint:ast": "bash -c 'fail=0; for f in ast-rules/target/*.yml; do ast-grep scan --rule \"$f\" . || fail=1; done; exit $fail'",
    "lint:ast:self": "bash -c 'fail=0; for f in ast-rules/self/*.yml; do ast-grep scan --rule \"$f\" src/ || fail=1; done; exit $fail'",
    "lint:paths": "bash scripts/lint-paths.sh",
    "lint:ast:all": "bun run lint:ast && bun run lint:ast:self && bun run lint:paths",
    "build:binary": "bash scripts/build-binary.sh",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.63.2",
    "@mariozechner/pi-ai": "^0.63.2",
    "@mariozechner/pi-coding-agent": "^0.63.2"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^5.7.0"
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}
